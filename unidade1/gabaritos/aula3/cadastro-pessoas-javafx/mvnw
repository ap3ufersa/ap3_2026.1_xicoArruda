#!/bin/sh
# Maven Wrapper - baixa e executa o Maven automaticamente
MAVEN_VERSION="3.9.6"
MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-${MAVEN_VERSION}"
MVN_CMD="$MAVEN_HOME/bin/mvn"

if [ ! -f "$MVN_CMD" ]; then
    echo "Baixando Maven ${MAVEN_VERSION}..."
    mkdir -p "$MAVEN_HOME"
    curl -sL "https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/${MAVEN_VERSION}/apache-maven-${MAVEN_VERSION}-bin.tar.gz" \
        | tar -xz -C "$HOME/.m2/wrapper/dists/"
fi

exec "$MVN_CMD" "$@"
